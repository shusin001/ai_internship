APP_NAME=recommended_jobs_ai
APP_VERSION=1.0.0
APP_DESCRIPTION=Backend-only recomendation ai with FastAPI + MongoDB Atlas

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=recommended_db_name

USAJOBS_BASE_URL=https://data.usajobs.gov/api/search
USAJOBS_API_HOST=data.usajobs.gov
USAJOBS_USER_AGENT=u757bk@gmail.com@example.com
USAJOBS_API_KEY=your_usajobs_api_key
USAJOBS_RESULTS_PER_PAGE=25
USAJOBS_KEYWORD=engineer, analyst, manager, specialist, scientist, technician, officer, coordinator, administrator
USAJOBS_LOCATION=

RSS_FEED_URL=https://remotive.com/remote-jobs/feed

SERPAPI_BASE_URL=https://serpapi.com/search.json
SERPAPI_ENGINE=google_jobs
SERPAPI_LOCATION=United States
SERPAPI_KEYWORDS=software engineer,data analyst,project manager,operations specialist,business analyst
SERPAPI_API_KEY=your_serpapi_key

JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

FETCH_INTERVAL_HOURS=6

# Optional Guidance LLM refinement (Gemini)
GUIDANCE_LLM_ENABLED=false
GEMINI_API_KEY=
GUIDANCE_GEMINI_MODEL=
